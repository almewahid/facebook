# Database
DATABASE_URL=sqlite:///./facebook_bot.db
# Neon/Postgres production example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Anthropic API (للذكاء الاصطناعي)
ANTHROPIC_API_KEY=your_api_key_here

# Facebook Credentials (اختياري - يمكن استخدام البروفايل المحفوظ)
FACEBOOK_EMAIL=your_email@example.com
FACEBOOK_PASSWORD=your_password

# Bot Settings
PAGE_URL=https://web.facebook.com/profile.php?id=YOUR_PAGE_ID
MAX_GROUPS_PER_SESSION=7
DELAY_BETWEEN_CYCLES=3600
MIN_DELAY_BETWEEN_GROUPS=60
MAX_DELAY_BETWEEN_GROUPS=120
MAX_AUTO_SHARE_TRIES=3

# Security
SECRET_KEY=your_secret_key_here_change_this_in_production

# Server
PORT=8000
HOST=0.0.0.0
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# Railway/Linux Chrome
CHROME_HEADLESS=1
CHROME_USER_DATA=/app/chrome_profile
CHROME_PROFILE_FOLDER=Default
MEDIA_DIR=uploaded_media
